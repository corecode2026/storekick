# ========================================
# إعدادات Kick OAuth
# سجّل تطبيقك على: https://kick.com/settings/developer
# ========================================
KICK_CLIENT_ID=your_client_id_here
KICK_CLIENT_SECRET=your_client_secret_here
KICK_REDIRECT_URI=http://localhost:3000/auth/callback

# ========================================
# كلمة سر الجلسات (غيّرها لقيمة عشوائية طويلة)
# ========================================
SESSION_SECRET=change_this_to_random_long_string

# ========================================
# مفتاح حماية لوحة الإدارة
# نفس القيمة لازم تكون بملف public/js/app.js داخل متغير ADMIN_KEY
# ========================================
ADMIN_KEY=change_this_admin_key

# ========================================
# منفذ السيرفر
# ========================================
PORT=3000
